# Google Maps Platform API key — enables Photorealistic 3D Tiles
# Get yours at: https://developers.google.com/maps/documentation/tile/get-api-key
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# Cesium Ion access token — enables Cesium World Terrain (elevation)
# Free tier available at: https://ion.cesium.com/
VITE_CESIUM_TOKEN=your_cesium_ion_token_here
